# Optional: server-side fallback keys (browser localStorage takes priority)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=

# ---- Email-MFA login (optional, leave blank to disable login feature) ----

# 32+ char random string. Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Comma-separated emails allowed to log in. Anyone else gets "not authorized".
ALLOWED_EMAILS=claude.fredchan31@gmail.com

# Resend API key from https://resend.com/api-keys (starts with re_...)
RESEND_API_KEY=

# Sender shown on the login email. Use Resend's onboarding domain to start,
# then switch to your own verified domain later.
EMAIL_FROM=Legal Research <onboarding@resend.dev>

# ---- Vercel KV (auto-injected when you add a KV database in Vercel) ----
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
